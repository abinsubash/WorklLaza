# Frontend Environment Variables
# Copy this file to .env.local and update the values

# API Configuration
VITE_API_URL=http://localhost:8000

# WebSocket Configuration (Real-time features)
VITE_WEBSOCKET_CHAT_URL=ws://localhost:8000/ws/chat/
VITE_WEBSOCKET_NOTIFICATIONS_URL=ws://localhost:8000/ws/notifications/

# Production Example (uncomment and adjust for production)
# VITE_API_URL=https://api.worklaza.site
# VITE_WEBSOCKET_CHAT_URL=wss://api.worklaza.site/ws/chat/
# VITE_WEBSOCKET_NOTIFICATIONS_URL=wss://api.worklaza.site/ws/notifications/
